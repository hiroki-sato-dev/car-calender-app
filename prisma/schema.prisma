generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  passwordHash     String
  createdAt        DateTime         @default(now())
  lineUserId       String?          @unique
  lineLinkCode     String?          @unique
  calendars        CalendarMember[]
  events           Event[]
  conversationState LineConversationState?
}

model Calendar {
  id          Int              @id @default(autoincrement())
  name        String
  shareCode   String           @unique
  lineGroupId String?
  isPersonal  Boolean          @default(false)
  createdBy   Int
  createdAt   DateTime         @default(now())
  members     CalendarMember[]
  events      Event[]
}

model LineConversationState {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  state      String   // "idle" | "waiting_title" | "waiting_datetime"
  title      String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model CalendarMember {
  id         Int      @id @default(autoincrement())
  calendarId Int
  userId     Int
  calendar   Calendar @relation(fields: [calendarId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Event {
  id         Int      @id @default(autoincrement())
  calendarId Int
  userId     Int
  title      String
  memo       String?
  startTime  DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
  calendar   Calendar @relation(fields: [calendarId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}
